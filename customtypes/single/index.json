{
  "format": "page",
  "id": "single",
  "label": "Offre d'emploi",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Titre",
          "placeholder": "Développeur NextJS"
        }
      },
      "date": {
        "type": "Date",
        "config": {
          "label": "Date de publication"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "multi": "paragraph,heading2,heading3,strong,em,hyperlink,list-item,o-list-item",
          "allowTargetBlank": true
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Technologies",
          "fields": {
            "tag": {
              "type": "Link",
              "config": {
                "label": "Tag",
                "select": "document",
                "customtypes": ["tag"],
                "allowTargetBlank": false
              }
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
